<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A0A1A">

    <!-- Header bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#0D1117"
        android:paddingHorizontal="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NonaShield"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#00D4FF"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:id="@+id/tvHubSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Fraud Detection Scenarios"
            android:textSize="11sp"
            android:textColor="#888888"
            android:layout_marginTop="2dp" />

    </LinearLayout>

    <!-- Category tab title strip -->
    <TextView
        android:id="@+id/tvCategoryTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Device / Runtime Integrity (RASP)"
        android:textSize="13sp"
        android:textStyle="bold"
        android:textColor="#00D4FF"
        android:background="#0A0F1A"
        android:paddingHorizontal="20dp"
        android:paddingVertical="10dp" />

    <!-- Fragment container fills available space above BottomNav -->
    <FrameLayout
        android:id="@+id/hubFragmentContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Bottom navigation — 5 tabs -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#0D1117"
        app:menu="@menu/bottom_nav_menu"
        app:itemIconTint="#00D4FF"
        app:itemTextColor="#AAAAAA"
        app:itemActiveIndicatorColor="#112233"
        app:labelVisibilityMode="labeled" />

</LinearLayout>
