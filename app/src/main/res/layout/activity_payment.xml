<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A1A"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <!-- Header row: Welcome + Risk badge -->
        <TextView
            android:id="@+id/tvWelcome"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Welcome"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/tvRiskTier"
            android:layout_marginTop="24dp" />

        <TextView
            android:id="@+id/tvRiskTier"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Risk: LOW"
            android:textSize="11sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:background="@drawable/bg_risk_badge"
            app:layout_constraintTop_toTopOf="@id/tvWelcome"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="@id/tvWelcome" />

        <TextView
            android:id="@+id/tvDeviceId"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Device: —"
            android:textSize="11sp"
            android:textColor="#666666"
            android:fontFamily="monospace"
            app:layout_constraintTop_toBottomOf="@id/tvWelcome"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="2dp" />

        <!-- ─── Demo 5: Behavioral Biometrics Live Panel ────────────────── -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardBiometrics"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#0D1117"
            app:cardCornerRadius="14dp"
            app:cardElevation="6dp"
            app:layout_constraintTop_toBottomOf="@id/tvDeviceId"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Header row: title + composite score badge -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🧬 Behavioral Biometrics"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF" />

                    <TextView
                        android:id="@+id/tvBioRiskBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CALIBRATING…"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="3dp"
                        android:background="#333333" />

                </LinearLayout>

                <!-- Calibration progress bar (hidden once calibrated) -->
                <LinearLayout
                    android:id="@+id/rowCalibration"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Calibrating user profile  "
                        android:textSize="11sp"
                        android:textColor="#888888" />

                    <ProgressBar
                        android:id="@+id/progressCalibration"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="0dp"
                        android:layout_height="8dp"
                        android:layout_weight="1"
                        android:max="100"
                        android:progress="0"
                        android:progressTint="#00D4FF" />

                    <TextView
                        android:id="@+id/tvCalibrationPct"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="  0%"
                        android:textSize="11sp"
                        android:textColor="#00D4FF" />

                </LinearLayout>

                <!-- 6-channel readings (compact grid) -->
                <!-- Row 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="6dp">

                    <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Pressure" android:textSize="10sp" android:textColor="#888888" />
                        <TextView android:id="@+id/tvBioPressure"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="🟢 0.00" android:textSize="11sp" android:textColor="#CCCCCC"
                            android:fontFamily="monospace" />
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Finger Size" android:textSize="10sp" android:textColor="#888888" />
                        <TextView android:id="@+id/tvBioFingerSize"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="🟢 0.0px" android:textSize="11sp" android:textColor="#CCCCCC"
                            android:fontFamily="monospace" />
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Swipe Speed" android:textSize="10sp" android:textColor="#888888" />
                        <TextView android:id="@+id/tvBioSwipe"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="🟢 0.0" android:textSize="11sp" android:textColor="#CCCCCC"
                            android:fontFamily="monospace" />
                    </LinearLayout>

                </LinearLayout>

                <!-- Row 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp">

                    <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Hesitation" android:textSize="10sp" android:textColor="#888888" />
                        <TextView android:id="@+id/tvBioHesitation"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="🟢 0ms" android:textSize="11sp" android:textColor="#CCCCCC"
                            android:fontFamily="monospace" />
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Phone Hold" android:textSize="10sp" android:textColor="#888888" />
                        <TextView android:id="@+id/tvBioPosture"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="🟢 0°" android:textSize="11sp" android:textColor="#CCCCCC"
                            android:fontFamily="monospace" />
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Grip Stability" android:textSize="10sp" android:textColor="#888888" />
                        <TextView android:id="@+id/tvBioGrip"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="🟢 0.00" android:textSize="11sp" android:textColor="#CCCCCC"
                            android:fontFamily="monospace" />
                    </LinearLayout>

                </LinearLayout>

                <!-- Composite deviation bar (visible in comparison mode) -->
                <LinearLayout
                    android:id="@+id/rowDeviationBar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="4dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Identity Deviation vs. Baseline"
                            android:textSize="11sp"
                            android:textColor="#AAAAAA" />

                        <TextView
                            android:id="@+id/tvDeviationPct"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0%"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#FF4444"
                            android:fontFamily="monospace" />

                    </LinearLayout>

                    <ProgressBar
                        android:id="@+id/progressDeviation"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="12dp"
                        android:max="100"
                        android:progress="0"
                        android:progressTint="#E02020"
                        android:progressBackgroundTint="#333333" />

                    <TextView
                        android:id="@+id/tvDeviationChannels"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textSize="10sp"
                        android:textColor="#FF8888"
                        android:fontFamily="monospace"
                        android:layout_marginTop="4dp" />

                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ─── Demo 5: Social Engineering Warning Banner ──────────────── -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardSocialEngWarning"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#3A0000"
            app:cardCornerRadius="12dp"
            app:cardElevation="8dp"
            app:layout_constraintTop_toBottomOf="@id/cardBiometrics"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="12dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="⚠️  SOCIAL ENGINEERING DETECTED"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#FF4444"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/tvSocialEngDetail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="This device was previously registered to a different user. Risk elevated to HIGH."
                    android:textSize="12sp"
                    android:textColor="#FFAAAA"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvSocialEngPreviousUser"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Previous user: —"
                    android:textSize="11sp"
                    android:textColor="#FF8888"
                    android:fontFamily="monospace" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Payment form card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardPayment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#111122"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            app:layout_constraintTop_toBottomOf="@id/cardSocialEngWarning"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Send Payment"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:layout_marginBottom="20dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Amount (INR)"
                    app:boxBackgroundColor="#0A0A1A"
                    app:boxStrokeColor="#00D4FF"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_marginBottom="12dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etAmount"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#FFFFFF"
                        android:inputType="numberDecimal"
                        android:imeOptions="actionNext" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Recipient ID or UPI"
                    app:boxBackgroundColor="#0A0A1A"
                    app:boxStrokeColor="#00D4FF"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_marginBottom="12dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etRecipient"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#FFFFFF"
                        android:inputType="textEmailAddress"
                        android:imeOptions="actionNext" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Note (optional)"
                    app:boxBackgroundColor="#0A0A1A"
                    app:boxStrokeColor="#00D4FF"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_marginBottom="20dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etNote"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#FFFFFF"
                        android:imeOptions="actionDone" />
                </com.google.android.material.textfield.TextInputLayout>

                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:indeterminateTint="#00D4FF"
                    android:layout_gravity="center"
                    android:visibility="gone"
                    android:layout_marginBottom="8dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSendPayment"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="Send Payment"
                    android:textSize="16sp"
                    android:textColor="#000000"
                    app:backgroundTint="#00D4FF"
                    app:cornerRadius="10dp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Result panel -->
        <TextView
            android:id="@+id/tvResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:background="#111122"
            android:fontFamily="monospace"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/cardPayment"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="16dp" />

        <!-- Demo 2: Non-Repudiation — View Proof button (appears after success) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnViewProof"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="🔏 View Non-Repudiation Receipt"
            android:textSize="13sp"
            android:textColor="#00FF88"
            app:backgroundTint="#0A1A0A"
            app:strokeColor="#00FF88"
            app:strokeWidth="1dp"
            app:cornerRadius="10dp"
            app:layout_constraintTop_toBottomOf="@id/tvResult"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="8dp"
            android:visibility="gone" />

        <!-- Dashboard button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnViewDashboard"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="View SOC Dashboard →"
            android:textSize="14sp"
            android:textColor="#00D4FF"
            app:backgroundTint="#0D1117"
            app:strokeColor="#00D4FF"
            app:strokeWidth="1dp"
            app:cornerRadius="10dp"
            app:layout_constraintTop_toBottomOf="@id/btnViewProof"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="12dp" />

        <!-- Demo 5: Switch User button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSwitchUser"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:text="Switch User (Demo 5)"
            android:textSize="12sp"
            android:textColor="#FFAA00"
            app:backgroundTint="#1A1100"
            app:strokeColor="#FFAA00"
            app:strokeWidth="1dp"
            app:cornerRadius="10dp"
            app:layout_constraintTop_toBottomOf="@id/btnViewDashboard"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnLogout"
            android:layout_marginTop="10dp"
            android:layout_marginEnd="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogout"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="Logout"
            android:textSize="13sp"
            android:textColor="#888888"
            app:backgroundTint="@android:color/transparent"
            app:layout_constraintTop_toBottomOf="@id/btnViewDashboard"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="32dp" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>
