<?xml version="1.0" encoding="utf-8"?>
<!--
  SocDashboardActivity — Full in-app SOC dashboard.
  Cards: Stats Bar · Live Decision Feed · Threat Event Log · Threat Breakdown · Actions
-->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A1A"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ── Header ───────────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp">

            <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="SOC Dashboard" android:textSize="22sp" android:textStyle="bold"
                    android:textColor="#FFFFFF" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Security Operations Centre" android:textSize="12sp"
                    android:textColor="#888888" />
            </LinearLayout>

            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical">
                <View android:id="@+id/viewSocLiveDot"
                    android:layout_width="8dp" android:layout_height="8dp"
                    android:background="#00FF88" android:layout_marginEnd="6dp" />
                <TextView android:id="@+id/tvSocPeriod"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="last 24h" android:textSize="11sp"
                    android:textColor="#888888" android:fontFamily="monospace" />
            </LinearLayout>
        </LinearLayout>

        <!-- ── Stats Bar ────────────────────────────────────────────────── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#0D1117"
            app:cardCornerRadius="14dp"
            app:cardElevation="6dp"
            android:layout_marginBottom="12dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="📊  Overview" android:textSize="14sp" android:textStyle="bold"
                    android:textColor="#FFFFFF" android:layout_marginBottom="14dp" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Total -->
                    <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content" android:orientation="vertical"
                        android:gravity="center_horizontal">
                        <TextView android:id="@+id/tvStatTotal"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="—" android:textSize="24sp" android:textStyle="bold"
                            android:textColor="#00D4FF" android:fontFamily="monospace" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Decisions" android:textSize="10sp" android:textColor="#888888" />
                    </LinearLayout>

                    <!-- Allowed -->
                    <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content" android:orientation="vertical"
                        android:gravity="center_horizontal">
                        <TextView android:id="@+id/tvStatAllowed"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="—" android:textSize="24sp" android:textStyle="bold"
                            android:textColor="#00AA44" android:fontFamily="monospace" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Allowed" android:textSize="10sp" android:textColor="#888888" />
                    </LinearLayout>

                    <!-- Step-Up -->
                    <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content" android:orientation="vertical"
                        android:gravity="center_horizontal">
                        <TextView android:id="@+id/tvStatStepUp"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="—" android:textSize="24sp" android:textStyle="bold"
                            android:textColor="#FFAA00" android:fontFamily="monospace" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Step-Up" android:textSize="10sp" android:textColor="#888888" />
                    </LinearLayout>

                    <!-- Blocked -->
                    <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content" android:orientation="vertical"
                        android:gravity="center_horizontal">
                        <TextView android:id="@+id/tvStatBlocked"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="—" android:textSize="24sp" android:textStyle="bold"
                            android:textColor="#DD2222" android:fontFamily="monospace" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Blocked" android:textSize="10sp" android:textColor="#888888" />
                    </LinearLayout>

                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="#1A1A2E" android:layout_marginTop="14dp"
                    android:layout_marginBottom="14dp" />

                <!-- Secondary stats row -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Avg Risk Score" android:textSize="10sp" android:textColor="#888888" />
                        <TextView android:id="@+id/tvStatAvgRisk"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="—" android:textSize="16sp" android:textStyle="bold"
                            android:textColor="#00D4FF" android:fontFamily="monospace" />
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Active Devices" android:textSize="10sp" android:textColor="#888888" />
                        <TextView android:id="@+id/tvStatDevices"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="—" android:textSize="16sp" android:textStyle="bold"
                            android:textColor="#CCCCCC" android:fontFamily="monospace" />
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Block Rate" android:textSize="10sp" android:textColor="#888888" />
                        <TextView android:id="@+id/tvStatBlockRate"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="—" android:textSize="16sp" android:textStyle="bold"
                            android:textColor="#FF6600" android:fontFamily="monospace" />
                    </LinearLayout>

                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── Live Decision Feed ────────────────────────────────────────── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#0D1117"
            app:cardCornerRadius="14dp"
            app:cardElevation="6dp"
            android:layout_marginBottom="12dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">
                    <TextView android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="⚡  Live Decision Feed"
                        android:textSize="14sp" android:textStyle="bold" android:textColor="#FFFFFF" />
                    <TextView android:id="@+id/tvDecisionRefresh"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="auto-refresh 5s" android:textSize="10sp"
                        android:textColor="#555555" android:fontFamily="monospace" />
                </LinearLayout>

                <!-- Column headers -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="6dp">
                    <TextView android:layout_width="0dp" android:layout_weight="2"
                        android:layout_height="wrap_content"
                        android:text="Device" android:textSize="10sp" android:textColor="#555555" />
                    <TextView android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Risk" android:textSize="10sp" android:textColor="#555555" />
                    <TextView android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Decision" android:textSize="10sp" android:textColor="#555555" />
                    <TextView android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="When" android:textSize="10sp" android:textColor="#555555" />
                </LinearLayout>

                <!-- Decision rows injected dynamically -->
                <LinearLayout android:id="@+id/llDecisionRows"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── Threat Event Log ──────────────────────────────────────────── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#0D1117"
            app:cardCornerRadius="14dp"
            app:cardElevation="6dp"
            android:layout_marginBottom="12dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="🚨  Threat Event Log"
                    android:textSize="14sp" android:textStyle="bold" android:textColor="#FFFFFF"
                    android:layout_marginBottom="12dp" />

                <!-- Threat rows injected dynamically -->
                <LinearLayout android:id="@+id/llThreatRows"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── Threat Breakdown by Category ─────────────────────────────── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#0D1117"
            app:cardCornerRadius="14dp"
            app:cardElevation="6dp"
            android:layout_marginBottom="12dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="📂  Threat Category Breakdown"
                    android:textSize="14sp" android:textStyle="bold" android:textColor="#FFFFFF"
                    android:layout_marginBottom="12dp" />

                <!-- RASP / Device -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    <TextView android:layout_width="120dp" android:layout_height="wrap_content"
                        android:text="RASP / Device" android:textSize="11sp" android:textColor="#AAAAAA" />
                    <ProgressBar android:id="@+id/progressRaspCat"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="0dp" android:layout_weight="1" android:layout_height="8dp"
                        android:max="100" android:progress="0" android:progressTint="#00D4FF"
                        android:progressBackgroundTint="#1A1A2E" />
                    <TextView android:id="@+id/tvRaspCatPct"
                        android:layout_width="36dp" android:layout_height="wrap_content"
                        android:text="0%" android:textSize="10sp" android:textColor="#00D4FF"
                        android:fontFamily="monospace" android:gravity="end" />
                </LinearLayout>

                <!-- Network -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    <TextView android:layout_width="120dp" android:layout_height="wrap_content"
                        android:text="Network / MITM" android:textSize="11sp" android:textColor="#AAAAAA" />
                    <ProgressBar android:id="@+id/progressNetCat"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="0dp" android:layout_weight="1" android:layout_height="8dp"
                        android:max="100" android:progress="0" android:progressTint="#FFAA00"
                        android:progressBackgroundTint="#1A1A2E" />
                    <TextView android:id="@+id/tvNetCatPct"
                        android:layout_width="36dp" android:layout_height="wrap_content"
                        android:text="0%" android:textSize="10sp" android:textColor="#FFAA00"
                        android:fontFamily="monospace" android:gravity="end" />
                </LinearLayout>

                <!-- Behavioral -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    <TextView android:layout_width="120dp" android:layout_height="wrap_content"
                        android:text="Behavioral" android:textSize="11sp" android:textColor="#AAAAAA" />
                    <ProgressBar android:id="@+id/progressBioCat"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="0dp" android:layout_weight="1" android:layout_height="8dp"
                        android:max="100" android:progress="0" android:progressTint="#FF6600"
                        android:progressBackgroundTint="#1A1A2E" />
                    <TextView android:id="@+id/tvBioCatPct"
                        android:layout_width="36dp" android:layout_height="wrap_content"
                        android:text="0%" android:textSize="10sp" android:textColor="#FF6600"
                        android:fontFamily="monospace" android:gravity="end" />
                </LinearLayout>

                <!-- App Integrity -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <TextView android:layout_width="120dp" android:layout_height="wrap_content"
                        android:text="App Integrity" android:textSize="11sp" android:textColor="#AAAAAA" />
                    <ProgressBar android:id="@+id/progressAppCat"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="0dp" android:layout_weight="1" android:layout_height="8dp"
                        android:max="100" android:progress="0" android:progressTint="#DD2222"
                        android:progressBackgroundTint="#1A1A2E" />
                    <TextView android:id="@+id/tvAppCatPct"
                        android:layout_width="36dp" android:layout_height="wrap_content"
                        android:text="0%" android:textSize="10sp" android:textColor="#DD2222"
                        android:fontFamily="monospace" android:gravity="end" />
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── Actions ───────────────────────────────────────────────────── -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOpenGrafanaSoc"
            android:layout_width="match_parent" android:layout_height="48dp"
            android:text="📈  Open Full Grafana Dashboard"
            android:textSize="13sp" android:textColor="#00D4FF"
            app:backgroundTint="#0D1117" app:strokeColor="#00D4FF" app:strokeWidth="1dp"
            app:cornerRadius="10dp" android:layout_marginBottom="10dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSocBack"
            android:layout_width="match_parent" android:layout_height="48dp"
            android:text="← Back"
            android:textSize="13sp" android:textColor="#888888"
            app:backgroundTint="@android:color/transparent"
            android:layout_marginBottom="32dp" />

    </LinearLayout>
</ScrollView>
