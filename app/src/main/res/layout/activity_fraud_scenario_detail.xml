<?xml version="1.0" encoding="utf-8"?>
<!--
  FraudScenarioDetailActivity — per-scenario signal trace + pipeline demo
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A0A1A">

    <!-- Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:background="#0D1117">

        <TextView
            android:id="@+id/btnDetailBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:text="←"
            android:textSize="20sp"
            android:textColor="#00D4FF"
            android:gravity="center" />

        <TextView
            android:id="@+id/tvDetailTitle"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Scenario"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginStart="8dp" />

        <TextView
            android:id="@+id/tvDetailSeverityBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CRITICAL"
            android:textSize="9sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp"
            android:background="#DD2222" />

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Description card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#0D1117"
                app:cardCornerRadius="12dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvDetailEmoji"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔐"
                        android:textSize="28sp"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/tvDetailDescription"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Description"
                        android:textSize="13sp"
                        android:textColor="#CCCCCC"
                        android:lineSpacingMultiplier="1.4"
                        android:layout_marginBottom="12dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="USE CASE #" android:textSize="9sp" android:textColor="#555555" />
                            <TextView android:id="@+id/tvDetailUseCaseNum"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="1" android:textSize="18sp" android:textStyle="bold"
                                android:textColor="#00D4FF" android:fontFamily="monospace" />
                        </LinearLayout>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_weight="2"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="BACKEND MODULE" android:textSize="9sp" android:textColor="#555555" />
                            <TextView android:id="@+id/tvDetailModule"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="mule_account" android:textSize="11sp"
                                android:textColor="#00FF88" android:fontFamily="monospace" />
                        </LinearLayout>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_weight="2"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="RBI RULE" android:textSize="9sp" android:textColor="#555555" />
                            <TextView android:id="@+id/tvDetailRbiRule"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="UC-01" android:textSize="11sp"
                                android:textColor="#FFAA00" android:fontFamily="monospace" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- SDK Signals card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#0D1117"
                app:cardCornerRadius="12dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📡  SDK Signals"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:layout_marginBottom="10dp" />

                    <LinearLayout
                        android:id="@+id/llSignalRows"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Pipeline trace card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#0D1117"
                app:cardCornerRadius="12dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="⚙  Backend Pipeline"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF" />

                        <TextView
                            android:id="@+id/tvPipelineLatency"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="— ms"
                            android:textSize="10sp"
                            android:textColor="#00FF88"
                            android:fontFamily="monospace" />
                    </LinearLayout>

                    <!-- Phase 1: Edge / NGINX -->
                    <LinearLayout android:id="@+id/rowPhase1"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:layout_marginBottom="6dp">
                        <TextView android:layout_width="20dp" android:layout_height="wrap_content"
                            android:text="1" android:textSize="10sp" android:textColor="#555555"
                            android:fontFamily="monospace" />
                        <View android:layout_width="8dp" android:layout_height="8dp"
                            android:id="@+id/dotPhase1" android:background="#333333"
                            android:layout_marginEnd="8dp" />
                        <TextView android:layout_width="0dp" android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="NGINX Edge — HMAC verify + rate limit"
                            android:textSize="11sp" android:textColor="#888888" />
                        <TextView android:id="@+id/tvPhase1Status"
                            android:layout_width="60dp" android:layout_height="wrap_content"
                            android:text="WAITING" android:textSize="9sp"
                            android:textColor="#444444" android:fontFamily="monospace"
                            android:gravity="end" />
                    </LinearLayout>

                    <!-- Phase 2: Crypto Gate -->
                    <LinearLayout android:id="@+id/rowPhase2"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:layout_marginBottom="6dp">
                        <TextView android:layout_width="20dp" android:layout_height="wrap_content"
                            android:text="2" android:textSize="10sp" android:textColor="#555555"
                            android:fontFamily="monospace" />
                        <View android:layout_width="8dp" android:layout_height="8dp"
                            android:id="@+id/dotPhase2" android:background="#333333"
                            android:layout_marginEnd="8dp" />
                        <TextView android:layout_width="0dp" android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="Crypto Gate — HybridSig + evidence chain"
                            android:textSize="11sp" android:textColor="#888888" />
                        <TextView android:id="@+id/tvPhase2Status"
                            android:layout_width="60dp" android:layout_height="wrap_content"
                            android:text="WAITING" android:textSize="9sp"
                            android:textColor="#444444" android:fontFamily="monospace"
                            android:gravity="end" />
                    </LinearLayout>

                    <!-- Phase 3: Compliance -->
                    <LinearLayout android:id="@+id/rowPhase3"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:layout_marginBottom="6dp">
                        <TextView android:layout_width="20dp" android:layout_height="wrap_content"
                            android:text="3" android:textSize="10sp" android:textColor="#555555"
                            android:fontFamily="monospace" />
                        <View android:layout_width="8dp" android:layout_height="8dp"
                            android:id="@+id/dotPhase3" android:background="#333333"
                            android:layout_marginEnd="8dp" />
                        <TextView android:layout_width="0dp" android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="Compliance — RBI threat_matrix match"
                            android:textSize="11sp" android:textColor="#888888" />
                        <TextView android:id="@+id/tvPhase3Status"
                            android:layout_width="60dp" android:layout_height="wrap_content"
                            android:text="WAITING" android:textSize="9sp"
                            android:textColor="#444444" android:fontFamily="monospace"
                            android:gravity="end" />
                    </LinearLayout>

                    <!-- Phase 4: ML Engine -->
                    <LinearLayout android:id="@+id/rowPhase4"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:layout_marginBottom="6dp">
                        <TextView android:layout_width="20dp" android:layout_height="wrap_content"
                            android:text="4" android:textSize="10sp" android:textColor="#555555"
                            android:fontFamily="monospace" />
                        <View android:layout_width="8dp" android:layout_height="8dp"
                            android:id="@+id/dotPhase4" android:background="#333333"
                            android:layout_marginEnd="8dp" />
                        <TextView android:layout_width="0dp" android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="ML Engine — gradient boost score"
                            android:textSize="11sp" android:textColor="#888888" />
                        <TextView android:id="@+id/tvPhase4Status"
                            android:layout_width="60dp" android:layout_height="wrap_content"
                            android:text="WAITING" android:textSize="9sp"
                            android:textColor="#444444" android:fontFamily="monospace"
                            android:gravity="end" />
                    </LinearLayout>

                    <!-- Phase 5: Threat Executor -->
                    <LinearLayout android:id="@+id/rowPhase5"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical">
                        <TextView android:layout_width="20dp" android:layout_height="wrap_content"
                            android:text="5" android:textSize="10sp" android:textColor="#555555"
                            android:fontFamily="monospace" />
                        <View android:layout_width="8dp" android:layout_height="8dp"
                            android:id="@+id/dotPhase5" android:background="#333333"
                            android:layout_marginEnd="8dp" />
                        <TextView android:layout_width="0dp" android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="Threat Executor — 7 modules parallel"
                            android:textSize="11sp" android:textColor="#888888" />
                        <TextView android:id="@+id/tvPhase5Status"
                            android:layout_width="60dp" android:layout_height="wrap_content"
                            android:text="WAITING" android:textSize="9sp"
                            android:textColor="#444444" android:fontFamily="monospace"
                            android:gravity="end" />
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Decision result card (hidden until triggered) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardDecisionResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#0D1117"
                app:cardCornerRadius="12dp"
                android:layout_marginBottom="12dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚖  Final Decision"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:layout_marginBottom="10dp" />

                    <TextView
                        android:id="@+id/tvDecisionVerdict"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="BLOCK"
                        android:textSize="32sp"
                        android:textStyle="bold"
                        android:textColor="#DD2222"
                        android:fontFamily="monospace"
                        android:gravity="center"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/tvDecisionReason"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Reason"
                        android:textSize="12sp"
                        android:textColor="#888888"
                        android:gravity="center"
                        android:layout_marginBottom="12dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                            android:layout_height="wrap_content" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="RISK SCORE" android:textSize="9sp" android:textColor="#555555" />
                            <TextView android:id="@+id/tvDecisionScore"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="—" android:textSize="20sp" android:textStyle="bold"
                                android:textColor="#DD2222" android:fontFamily="monospace" />
                        </LinearLayout>

                        <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                            android:layout_height="wrap_content" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="MODULES HIT" android:textSize="9sp" android:textColor="#555555" />
                            <TextView android:id="@+id/tvDecisionModulesHit"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="—" android:textSize="20sp" android:textStyle="bold"
                                android:textColor="#FFAA00" android:fontFamily="monospace" />
                        </LinearLayout>

                        <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                            android:layout_height="wrap_content" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="LATENCY" android:textSize="9sp" android:textColor="#555555" />
                            <TextView android:id="@+id/tvDecisionLatency"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="—" android:textSize="20sp" android:textStyle="bold"
                                android:textColor="#00FF88" android:fontFamily="monospace" />
                        </LinearLayout>

                    </LinearLayout>

                    <!-- Evidence hash -->
                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="#1A1A2E" android:layout_marginVertical="12dp" />

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="EVIDENCE CHAIN HASH" android:textSize="9sp" android:textColor="#555555"
                        android:layout_marginBottom="4dp" />
                    <TextView android:id="@+id/tvDecisionEvidenceHash"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="sha256:—"
                        android:textSize="9sp" android:textColor="#00FF88"
                        android:fontFamily="monospace" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Log output card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#050510"
                app:cardCornerRadius="12dp"
                android:layout_marginBottom="12dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PIPELINE LOG"
                        android:textSize="9sp"
                        android:textColor="#555555"
                        android:fontFamily="monospace"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:id="@+id/tvPipelineLog"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textSize="9sp"
                        android:textColor="#00FF88"
                        android:fontFamily="monospace"
                        android:lineSpacingMultiplier="1.5" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom trigger button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="#0D1117">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTriggerAttack"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="▶  TRIGGER ATTACK SIMULATION"
            android:textSize="14sp"
            android:textColor="#000000"
            app:backgroundTint="#DD2222"
            app:cornerRadius="10dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnResetDemo"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:text="↺  Reset"
            android:textSize="12sp"
            android:textColor="#555555"
            app:backgroundTint="@android:color/transparent"
            android:visibility="gone" />

    </LinearLayout>

</LinearLayout>
